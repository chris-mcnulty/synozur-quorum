    "mammoth": "^1.8.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "openid-client": "^6.1.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.2",
    "pino": "^9",
